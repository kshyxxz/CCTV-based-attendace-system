# backend/services/embedding_service.py

import numpy as np
from backend.vision.camera import load_video, release_camera
from backend.vision.mtcnn_detector import load_detector, detect_faces, extract_face
from backend.vision.embedding import generate_embedding_for_one
from backend.database.models import Embedding
from backend.database.database import SessionLocal


def register_student(video_path, rollno, frame_skip=10):
    """
    Generate embeddings from a registration video and save to DB.
    Args:
        video_path (str): Path to the student's registration video.
        rollno (str): Student roll number (primary key).
        frame_skip (int): Process every Nth frame.
    Returns:
        int: Number of embeddings saved.
    """
    cap = load_video(video_path)
    detector = load_detector()
    frame_count = 0
    embeddings = []

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        frame_count += 1
        if frame_count % frame_skip != 0:
            continue

        faces = detect_faces(detector, frame)
        if len(faces) != 1:
            continue  # skip if not exactly one face

        box = faces[0]['box']
        face = extract_face(frame, box)
        embedding = generate_embedding_for_one(face)

        if embedding is not None:
            embeddings.append(embedding)

    release_camera(cap)

    # Save embeddings to DB
    db = SessionLocal()
    try:
        for emb in embeddings:
            emb_record = Embedding(
                rollno=rollno,
                embedding=np.array(emb, dtype=float)  # pgvector expects numeric array
            )
            db.add(emb_record)

        db.commit()
    finally:
        db.close()

    return len(embeddings)


if __name__ == "__main__":
    print("Embedding service ready. Import and call register_student(video_path, rollno).")
